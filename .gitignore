# Composer dependencies are installed during CI/release builds.
/vendor/
/vendor-bin/

# Node tooling and package manager caches.
/node_modules/
/.npm/
/.yarn/

# Release/build artifacts.
/dist/
/build/
*.zip
*.tar
*.tar.gz
*.tgz
*.map

# PHPUnit, PHPCS, and local test output.
/.phpunit.result.cache
/coverage/
/.phpcs-cache
/tests/_output/

# Local environment and secrets.
.env
.env.*
!.env.example
*.local

# WordPress/local tooling files.
/wp-content/debug.log
/debug.log

# OS and editor noise.
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# Logs and temporary files.
*.log
*.tmp
*.temp
.cache/
