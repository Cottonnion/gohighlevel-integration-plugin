<?xml version="1.0"?>
<ruleset name="GHL CRM Integration">
    <description>WordPress coding standards for GHL CRM Integration plugin</description>

    <!-- Check all PHP files in these directories -->
    <file>./src</file>
    <file>./syncly.php</file>
    <file>./templates</file>

    <!-- Exclude vendor and other third-party directories -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/assets/admin/js/*</exclude-pattern>
    <exclude-pattern>*/assets/admin/css/*</exclude-pattern>

    <!-- Use WordPress coding standards -->
    <rule ref="WordPress-Extra">
        <!-- Allow short array syntax (modern PHP) -->
        <exclude name="Generic.Arrays.DisallowShortArraySyntax"/>
        <exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
        
        <!-- Allow snake_case file names (WordPress convention) -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
        
        <!-- Don't require strict comparison for certain cases -->
        <exclude name="WordPress.PHP.StrictComparisons.LooseComparison"/>
        
        <!-- Allow multiple assignments in one statement -->
        <exclude name="Squiz.PHP.DisallowMultipleAssignments"/>
        
        <!-- Don't require text domain in every string -->
        <exclude name="WordPress.WP.I18n.MissingTranslatorsComment"/>
        <exclude name="WordPress.WP.I18n.NonSingularStringLiteralDomain"/>
        
        <!-- Allow closures without specific spacing -->
        <exclude name="Squiz.Functions.MultiLineFunctionDeclaration.BraceOnSameLine"/>

        <!-- Don't require file docblocks -->
        <exclude name="Squiz.Commenting.FileComment.Missing"/>
        
        <!-- Allow inline comments without ending punctuation -->
        <exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>

        <!-- Noisy doc rules — not real bugs -->
        <exclude name="Squiz.Commenting.FunctionComment.ParamCommentFullStop"/>
        <exclude name="Squiz.Commenting.FunctionComment.ThrowsNoFullStop"/>

        <!-- Template files legitimately use short variable names -->
        <exclude name="WordPress.NamingConventions.PrefixAllGlobals.NonPrefixedVariableFound"/>

        <!-- Short ternaries are fine in modern PHP -->
        <exclude name="Universal.Operators.DisallowShortTernary.Found"/>

        <!-- Reserved-keyword parameter names ($global etc.) are intentional -->
        <exclude name="Universal.NamingConventions.NoReservedKeywordParameterNames"/>

        <!-- Nonce is verified before template includes — false positives in partials -->
        <exclude name="WordPress.Security.NonceVerification.Missing"/>

        <!-- Yoda conditions are a style preference, not a bug -->
        <exclude name="WordPress.PHP.YodaConditions.NotYoda"/>

        <!-- Empty catch/if blocks are intentional in some handlers -->
        <exclude name="Generic.CodeAnalysis.EmptyStatement.DetectedCatch"/>
        <exclude name="Generic.CodeAnalysis.EmptyStatement.DetectedIf"/>
        <exclude name="Generic.CodeAnalysis.EmptyStatement.DetectedElse"/>

        <!-- Commented-out code kept for reference is acceptable -->
        <exclude name="Squiz.PHP.CommentedOutCode.Found"/>

        <!-- Hook callbacks must match WordPress signatures even if not all params are used -->
        <exclude name="Generic.CodeAnalysis.UnusedFunctionParameter.FoundAfterLastUsed"/>
        <exclude name="Generic.CodeAnalysis.UnusedFunctionParameter.Found"/>

        <!-- Table names use $wpdb->prefix which can't be parameterized — suppress false positives -->
        <exclude name="WordPress.DB.PreparedSQL.InterpolatedNotPrepared"/>
        <exclude name="WordPress.DB.PreparedSQL.NotPrepared"/>

        <!-- NonceVerification.Recommended is a warning for $_GET/$_REQUEST reads — nonce checked upstream -->
        <exclude name="WordPress.Security.NonceVerification.Recommended"/>

        <!-- ExceptionNotEscaped targets thrown exception payloads/messages, not browser output -->
        <exclude name="WordPress.Security.EscapeOutput.ExceptionNotEscaped"/>
    </rule>

    <!-- Set minimum PHP version -->
    <config name="minimum_supported_wp_version" value="6.0"/>
    <config name="testVersion" value="7.4-"/>

    <!-- Custom rules for this project -->
    <rule ref="Generic.PHP.ForbiddenFunctions">
        <properties>
            <property name="forbiddenFunctions" type="array">
                <!-- Discourage dangerous functions -->
                <element key="eval" value="null"/>
                <element key="exec" value="null"/>
                <element key="system" value="null"/>
                <element key="shell_exec" value="null"/>
                <element key="passthru" value="null"/>
                <!-- Encourage WordPress alternatives -->
                <element key="curl_init" value="wp_remote_get"/>
                <element key="file_get_contents" value="wp_remote_get"/>
            </property>
        </properties>
    </rule>

    <!-- Text domain should match plugin slug -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="syncly"/>
            </property>
        </properties>
    </rule>

    <!-- Prefix for global functions and variables -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="ghl_crm"/>
                <element value="GHL_CRM"/>
            </property>
        </properties>
    </rule>

    <!-- File encoding -->
    <arg name="encoding" value="utf-8"/>
    
    <!-- Show colors in output -->
    <arg name="colors"/>
    
    <!-- Show progress -->
    <arg value="p"/>
    
    <!-- Show sniff codes -->
    <arg value="s"/>
    
    <!-- Extensions to check -->
    <arg name="extensions" value="php"/>
    
    <!-- Parallel processing -->
    <arg name="parallel" value="8"/>
</ruleset>
