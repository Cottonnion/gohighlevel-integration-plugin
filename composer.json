{
  "name": "labgenz/syncly",
  "description": "Syncly for GoHighLevel",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Yahya Eddaqqaq",
      "email": "yahyadard@gmail.com"
    }
  ],
  "require": {
    "php": ">=7.4",
    "woocommerce/action-scheduler": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "Syncly\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "platform": {
      "php": "7.4"
    },
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
